# --- Database (PostgreSQL / Prisma) ---
# Örnek: Supabase, Railway, Neon veya lokal Postgres bağlantı adresin
DATABASE_URL="postgresql://user:password@localhost:5432/koleksiyon_db?schema=public"

# --- JWT Auth ---
# Rastgele, uzun ve tahmin edilemez bir değer kullanın (örn: `openssl rand -base64 48`)
JWT_SECRET="cok-gizli-ve-uzun-bir-anahtar-buraya-yazilmali"
JWT_EXPIRES_IN="7d"

# --- İlk admin kullanıcısı (sadece seed script'i için kullanılır) ---
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="GucluBirSifre123!"

# --- Supabase Storage (görsel yükleme) ---
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="service-role-key" # Sadece sunucu tarafında kullanılır, asla client'a sızdırılmamalı
SUPABASE_STORAGE_BUCKET="koleksiyon-gorseller"

# --- Genel ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
